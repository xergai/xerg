{
  "name": "@xerg/cli",
  "version": "0.4.0",
  "description": "Audit OpenClaw and Hermes workflows in dollars, compare fixes, and export daily spend and waste trends.",
  "keywords": [
    "xerg",
    "ai",
    "agents",
    "finops",
    "llm",
    "openclaw",
    "hermes",
    "cost",
    "cli",
    "cursor",
    "analytics"
  ],
  "homepage": "https://xerg.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xergai/xerg.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "email": "query@xerg.ai",
    "url": "https://xerg.ai"
  },
  "author": "Xerg <query@xerg.ai>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "xerg": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md", "LICENSE", "skills"],
  "main": "./dist/index.js",
