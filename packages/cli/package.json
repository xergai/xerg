    "dev": "tsx src/index.ts",
    "prepack": "node ../../scripts/sync-cli-skill.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@xerg/schemas": "workspace:*",
    "@xergai/core": "workspace:*"
  }
