{
  "name": "xerg-workspace",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test:coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "corepack pnpm --filter @xerg/schemas build && corepack pnpm -r typecheck",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "changeset version",
    "release:beta": "changeset publish --tag beta",
    "cli:dev": "corepack pnpm --filter @xerg/cli dev",
    "cli:pack": "corepack pnpm --filter @xerg/cli exec npm pack --dry-run",
    "cli:smoke": "node scripts/smoke-cli-package.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,jsonc,md,mdx,yml,yaml}": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
